# Dependencies (recursive)
**/node_modules/
**/.pnp
**/.pnp.js

# Local env files (recursive)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Testing
**/coverage/

# Turbo
**/.turbo/

# Vercel
**/.vercel/

# Build Outputs (recursive)
**/.next/
**/out/
**/build/
**/dist/

# Debug logs (recursive)
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Misc (recursive)
**/.DS_Store
**/*.pem
